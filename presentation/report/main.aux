\@writefile{toc}{\contentsline {subsection}{\numberline {4.5.1}Multi-File Documents}{31}{subsection.4.5.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.5}{\ignorespaces Collaboration architecture. Clients connect to the Hocuspocus server over WebSocket. Document state is held in memory by Hocuspocus and replicated to Redis for cross-process consistency. Snapshots are persisted to PostgreSQL on a configurable interval. Logically, all clients participate in a single CRDT; physically, the server mediates message delivery for efficiency and authentication.}}{32}{figure.caption.20}\protected@file@percent }
\newlabel{fig:collab}{{4.5}{32}{Collaboration architecture. Clients connect to the Hocuspocus server over WebSocket. Document state is held in memory by Hocuspocus and replicated to Redis for cross-process consistency. Snapshots are persisted to PostgreSQL on a configurable interval. Logically, all clients participate in a single CRDT; physically, the server mediates message delivery for efficiency and authentication}{figure.caption.20}{}}
