\@writefile{lof}{\contentsline {figure}{\numberline {4.4}{\ignorespaces Paper discovery in ScholarHub{} with results displayed. The query \emph  {``arabic character-level BERT pretraining''} returns 20 deduplicated, relevance-ranked papers from seven sources in parallel (Crossref 20, ScienceDirect 20, OpenAlex 20, Europe PMC 20, CORE 9, arXiv 1, PubMed 0; Semantic Scholar was rate-limited and surfaces a Retry control). Each result shows its relevance score, source badge, year, venue, abstract excerpt, and one-click Add or Dismiss.}}{31}{figure.caption.19}\protected@file@percent }
\newlabel{fig:ss-discovery-inline}{{4.4}{31}{Paper discovery in \sh {} with results displayed. The query \emph {``arabic character-level BERT pretraining''} returns 20 deduplicated, relevance-ranked papers from seven sources in parallel (Crossref 20, ScienceDirect 20, OpenAlex 20, Europe PMC 20, CORE 9, arXiv 1, PubMed 0; Semantic Scholar was rate-limited and surfaces a Retry control). Each result shows its relevance score, source badge, year, venue, abstract excerpt, and one-click Add or Dismiss}{figure.caption.19}{}}
\@writefile{toc}{\contentsline {section}{\numberline {4.5}Real-Time Collaboration}{31}{section.4.5}\protected@file@percent }
