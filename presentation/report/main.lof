\contentsline {figure}{\numberline {C.1}{\ignorespaces Sign-in page. Authentication is by email and password or by Google OAuth. A short-lived session cookie is issued on success.}}{82}{figure.caption.51}%
\contentsline {figure}{\numberline {C.2}{\ignorespaces Account creation page. New users provide name, institutional email, and password. Google OAuth is also available.}}{82}{figure.caption.52}%
\contentsline {figure}{\numberline {C.3}{\ignorespaces Marketing landing page. The site presents the integrated workspace's value proposition before sign-up, with a live preview of the editor.}}{83}{figure.caption.53}%
\contentsline {figure}{\numberline {C.4}{\ignorespaces Paper discovery interface. The user enters a query, selects which sources to include, and receives streamed deduplicated results.}}{83}{figure.caption.54}%
\contentsline {figure}{\numberline {C.5}{\ignorespaces Discovery feed view. Recommended papers based on the project's keywords and library content stream in continuously.}}{84}{figure.caption.55}%
\addvspace {10\p@ }
